/*
 * nextflow.config
 * ---------------
 * Global configuration for your pipeline.
 * Settings here apply to every run unless overridden.
 */

// Default pipeline parameters (can be overridden with --param on CLI)
params {
    input    = "$projectDir/data/*.txt"
    outdir   = "$projectDir/results"
    greeting = "Hello"
}

// Execution profiles — switch with: nextflow run main.nf -profile docker
profiles {

    // Standard profile: runs locally with no container
    standard {
        process.executor = 'local'
    }

    // Docker profile: runs each process inside a Docker container
    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.container = 'ubuntu:22.04'  // replace with your preferred image
    }

    // Singularity profile: common on HPC clusters
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        process.container      = 'docker://ubuntu:22.04'
    }

    // Test profile: uses tiny test data for quick validation
    test {
        params.input    = "$projectDir/data/*.txt"
        params.greeting = "Test greeting"
    }
}

// Capture execution reports (uncomment to enable)
